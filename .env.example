# =================================================================
# BSF-NUTRIFEED API CONFIGURATION
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit the actual '.env' file to Version Control (Git).
# =================================================================

# --- MySQL Database Configuration ---
MYSQL_ROOT_PASSWORD=root_password_here
MYSQL_DATABASE=bsf_nutrifeed_db
MYSQL_USER=bsf_user
MYSQL_PASSWORD=bsf_password_here

# --- Flask API Configuration ---
BSF_PORT=5050
DB_TYPE=mysql
JWT_SECRET_KEY=a unique id

# --- Redis Configuration ---
REDIS_HOST=redis-cache

# --- SQLAlchemy URI Format ---
# Internal Docker connection string:
# mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@db:3306/${MYSQL_DATABASE}
